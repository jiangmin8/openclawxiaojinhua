#!/bin/bash
# PC巡检脚本 — 每30分钟执行一次
# 调度: */30 * * * *
# 环境: WSL2 (Ubuntu 22.04.5 LTS)

echo "=== PC巡检 - $(date '+%F %H:%M:%S') ===" > /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
echo "=== 磁盘使用 ===" >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
df -h | awk '$5+0 > 80 {print $0}' >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
echo "=== 内存使用 ===" >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
free -h | awk '/Mem:/{if($4+0 > 4) print $0}' >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
echo "=== Ollama 模型列表 ===" >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
ollama list >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log 2>&1
echo "=== NVIDIA GPU 状态 ===" >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
nvidia-smi >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log 2>&1
echo "=== 临时目录大文件 ===" >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
ls -lhS /tmp | head -5 >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log

# 如果没有任何异常，输出正常状态
if [ ! -s /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log ]; then
    echo "无异常项" >> /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log
fi

# 清理超过7天的巡检日志
find /tmp -name "pc_inspe_*.log" -mtime +7 -delete

echo "巡检完成，日志保存为: /tmp/pc_inspe_$(date '+%Y%m%d_%H%M%S').log"